					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-14T11:56:25.516919+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-14T11:56:25.516919+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "pcydisGbQoW8BlpOcMlaCA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "El modelo no solo refleja: también actúa. Para los registros #setClear jamás se escribe un valor crudo — el hardware lo malinterpretaría como un comando SET o CLR arbitrario —, así que write: está prohibido en ellos y en su lugar existen setBits:/clearBits: y, con los nombres de campo del NDK, enable:/disable:. El siguiente snippet apaga el DMA de bitplanes (la pantalla del Amiga se queda plana, del color de fondo COLOR00), espera dos segundos y lo vuelve a encender, devolviendo el valor de DMACON leído a través de DMACONR. Mira la ventana de FS-UAE mientras lo ejecutas:"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-14T11:56:33.303351+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-14T11:56:33.303351+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "gFdkvQn6RA+bMF2oJwH5Vw=="
				},
				"code" : "| dmacon |\ndmacon := GT4AmigaChipRegisters default at: 'DMACON'.\ndmacon disable: 'BPLEN'.\n2 seconds wait.\ndmacon enable: 'BPLEN'.\n'$' , (dmacon read printPaddedWith: $0 to: 4 base: 16)"
			},
			{
