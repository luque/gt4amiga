				"uid" : {
					"__type" : "uid",
					"uidString" : "PRoghu6WSIWeuwORh+HX7w=="
				},
				"code" : "\"Paso 3: restaurar el Workbench por software y liberar la lista.\"\n| monitor catalogo lof clist |\nmonitor := GT4AmigaMonitorClient default.\ncatalogo := GT4AmigaMachine default catalog.\nSmalltalk at: #GT4ABarsAnim put: false.\n[ Smalltalk at: #GT4ABarsAnimRunning ifAbsent: [ false ] ]\n\twhileTrue: [ (Delay forMilliseconds: 100) wait ].\nclist := Smalltalk at: #GT4ABarsList ifAbsent: [ ^ 'no hay lista instalada' ].\nlof := monitor readMemoryAt: catalogo gfxBase + 50 size: 4.\n(lof isNil or: [ lof = 0 ]) ifTrue: [ ^ 'LOFlist ilegible — no toco nada' ].\n{ 16rDFF096 -> 16r0080.\n  16rDFF080 -> (lof bitShift: -16).\n  16rDFF082 -> (lof bitAnd: 16rFFFF).\n  16rDFF096 -> 16r8180 }\n\tdo: [ :par | monitor writeMemoryAt: par key size: 2 value: par value ].\n(Delay forMilliseconds: 200) wait.\nmonitor callLibrary: 0 lvo: -210 a0: 0 a1: clist\n\td0: (Smalltalk at: #GT4ABarsSize) d1: 0 d2: 0 d3: 0.\nSmalltalk globals removeKey: #GT4ABarsList.\nSmalltalk globals removeKey: #GT4ABarsSize.\n'Workbench de vuelta, chip RAM liberada'"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
