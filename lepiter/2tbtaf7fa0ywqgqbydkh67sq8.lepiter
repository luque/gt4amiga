					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-16T00:33:54.923087+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-16T00:33:54.923087+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "zrtu13bBSfat9IJKliRLEw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Y la deuda, saldada. El capítulo del split terminaba con \"para recuperar el Workbench, reinicia\" porque no sabíamos recargar COP1LC con la lista del sistema. Ahora sí: la lista del Workbench sigue intacta en chip RAM — nunca la tocamos, solo dejamos de ejecutarla — y GfxBase la apunta en LOFlist (offset 50, graphics/gfxbase.i), el mismo campo del que el catálogo de registros deriva BPLCON0 o DDFSTRT. La secuencia importa: parar la animación y esperar a que confirme (un frame en vuelo no debe escribir sobre memoria que vamos a liberar), COPEN fuera, COP1LC de vuelta a la lista del sistema, DMACON $8180 (SET + BPLEN + COPEN) para reencender lo que apagamos... y solo ENTONCES liberar nuestra chip RAM. La regla del split sigue en pie: jamás liberes una copper list que el hardware pueda estar ejecutando."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-16T00:34:07.823479+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-16T00:34:07.823479+02:00"
					}
