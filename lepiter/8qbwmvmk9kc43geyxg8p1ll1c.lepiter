						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T23:07:35.543531+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T23:07:35.543531+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "ersp3UXXRlG3+rzZ+U4KOA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "La demo: vamos a traer la pantalla real del Amiga a esta página. Primero hay que encontrarla. Intuition guarda sus pantallas como una lista enlazada cuyo primer eslabón ya sabemos leer (IntuitionBase→FirstScreen, el comando S). Dentro de la estructura Screen, tras el ViewPort (offset 44, tamaño 40) y el RastPort (tamaño 100), vive un BitMap embebido en el offset 184 — offsets verificados contra intuition/screens.i, graphics/view.i y graphics/rastport.i del NDK. El BitMap nos da la geometría y, sobre todo, los punteros a los planos: BytesPerRow (+0), Rows (+2), Depth (+5) y Planes[8] (+8). Workbench 1.3 es 640×256 con 2 planos: 80 bytes por fila, 20480 bytes por plano."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
