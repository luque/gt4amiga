					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T23:08:31.099217+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T23:08:31.099217+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "UuvD3LrrQ8Ct+pMX6O3wEA=="
				},
				"code" : "\"La pantalla de Workbench, leída del Amiga vivo y compuesta como Form\"\n| c screen bpr rows w cmap p0bits p1bits argbs form bits |\nc := GT4AmigaMonitorClient default.\nscreen := c workbenchScreenPointer.\nbpr := c readMemoryAt: screen + 184 size: 2.\nrows := c readMemoryAt: screen + 186 size: 2.\nw := bpr * 8.\ncmap := c readMemoryAt: screen + 48 size: 4.\np0bits := c readMemoryAt: (c readMemoryAt: screen + 192 size: 4) length: bpr * rows.\np1bits := c readMemoryAt: (c readMemoryAt: screen + 196 size: 4) length: bpr * rows.\nargbs := (0 to: 3) collect: [ :i |\n\t| rgb4 |\n\trgb4 := c callLibrary: 3 lvo: -582 a0: cmap a1: 0 d0: i d1: 0 d2: 0 d3: 0.\n\t(Color\n\t\tr: ((rgb4 bitShift: -8) bitAnd: 15) / 15\n\t\tg: ((rgb4 bitShift: -4) bitAnd: 15) / 15\n\t\tb: (rgb4 bitAnd: 15) / 15) pixelValueForDepth: 32 ].\nform := Form extent: w @ rows depth: 32.\nbits := form bits.\n0 to: rows - 1 do: [ :y |\n\t0 to: bpr - 1 do: [ :bx |\n\t\t| b0 b1 base |\n\t\tb0 := p0bits at: y * bpr + bx + 1.\n\t\tb1 := p1bits at: y * bpr + bx + 1.\n\t\tbase := y * w + (bx * 8).\n\t\t0 to: 7 do: [ :bit |\n\t\t\t| mask idx |\n\t\t\tmask := 1 bitShift: 7 - bit.\n\t\t\tidx := ((b0 bitAnd: mask) = 0 ifTrue: [ 0 ] ifFalse: [ 1 ])\n\t\t\t\t+ ((b1 bitAnd: mask) = 0 ifTrue: [ 0 ] ifFalse: [ 2 ]).\n\t\t\tbits at: base + bit + 1 put: (argbs at: idx + 1) ] ] ].\nform"
			},
