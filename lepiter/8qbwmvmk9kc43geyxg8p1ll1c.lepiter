				"uid" : {
					"__type" : "uid",
					"uidString" : "r9QnXwEgQlmZBwMay3QImQ=="
				},
				"code" : "\"Navegar Screen -> BitMap con lecturas pequeñas (R): geometría y planos\"\n| c screen |\nc := GT4AmigaMonitorClient default.\nscreen := c workbenchScreenPointer.\n{ 'screen' -> screen.\n  'bytesPerRow' -> (c readMemoryAt: screen + 184 size: 2).\n  'rows' -> (c readMemoryAt: screen + 186 size: 2).\n  'depth' -> (c readMemoryAt: screen + 189 size: 1).\n  'plane0' -> (c readMemoryAt: screen + 192 size: 4).\n  'plane1' -> (c readMemoryAt: screen + 196 size: 4) }"
			},
			{
				"__type" : "textSnippet",
				"children" : {
