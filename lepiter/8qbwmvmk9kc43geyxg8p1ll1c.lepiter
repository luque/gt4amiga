					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-11T23:08:06.153953+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
