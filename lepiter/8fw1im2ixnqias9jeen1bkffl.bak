				"code" : "; Toma y liberación ordenada del hardware del Amiga\n; Adaptado del capítulo 4 de \"Amiga Assembly Game Programming\" (Stefano Coppi)\n; github.com/stefanocoppi/amiga_game_prog_assembly\n;\n; Self-contained: sin includes externos (NDK), sin registros AGA\n; (FMODE/BPLCON3/BPLCON4 del original, que no existen en el A500/Kickstart\n; 1.3 de este libro), y cicla una paleta de colores en vez de esperar un\n; clic de ratón, para que el resultado sea observable y el programa\n; termine solo en una ejecución desatendida.\n\n        SECTION code,CODE\n\nCUSTOM     equ     $dff000\nDMACONR    equ     $002\nDMACON     equ     $096\nCOLOR00    equ     $180\nDMASET     equ     %1000001000000000\nNUMCOLORS  equ     8\nDELAYCOUNT equ     200000\n\nstart:\n        movem.l d2-d7/a2-a6,-(sp)\n\n        ; --- Mensaje \"antes\": el sistema operativo funciona con normalidad ---\n        bsr     print_before\n\n        ; --- Tomamos el control del hardware ---\n        bsr     take_system\n\n        ; --- Aquí el programa es dueño absoluto del hardware: ni el\n        ;     multitasking ni las interrupciones pueden interrumpirnos.\n        ;     Ciclamos una paleta de 8 colores por COLOR00 (fondo/borde),\n        ;     dejando cada uno visible un instante, para que el cambio se\n        ;     aprecie en pantalla en vez de ser un parpadeo demasiado\n        ;     rápido para percibir. ---\n        lea     colortable,a0\n        moveq   #NUMCOLORS-1,d5\ncolorloop:\n        move.w  (a0)+,COLOR00(a5)\n        bsr     delay\n        dbra    d5,colorloop\n\n        ; --- Liberamos el hardware: el SO recupera el control ---\n        bsr     release_system\n\n        ; --- Mensaje \"después\": si esto se ve, el SO sigue operativo ---\n        bsr     print_after\n\n        movem.l (sp)+,d2-d7/a2-a6\n        moveq   #0,d0\n        rts\n\n;----------------------------------------------------------------\n; Espera ocupada: no podemos usar Delay()/Wait() de dos.library/exec\n; porque las interrupciones están deshabilitadas mientras dura la\n; toma de hardware (Disable()) - solo sirve un bucle de CPU pura.\n; DELAYCOUNT es una cifra aproximada, ajustada a ojo para que cada\n; color se vea con comodidad en un A500 a 7.09 MHz.\n;----------------------------------------------------------------\ndelay:\n        move.l  #DELAYCOUNT,d6\ndelayloop:\n        subq.l  #1,d6\n        bne.s   delayloop\n        rts\n\n;----------------------------------------------------------------\n; Toma control del hardware: multitasking, interrupciones y DMA.\n;----------------------------------------------------------------\ntake_system:\n        move.l  4.w,a6              ; a6 = ExecBase\n        jsr     -132(a6)            ; Exec Forbid() - nadie más recibe la CPU\n        jsr     -120(a6)            ; Exec Disable() - ni siquiera las interrupciones\n\n        lea     CUSTOM,a5           ; a5 = base de los chips personalizados ($DFF000)\n        move.w  DMACONR(a5),old_dma ; guardamos el estado actual de DMA\n        move.w  #$7fff,DMACON(a5)   ; apagamos todos los canales DMA\n        move.w  #DMASET,DMACON(a5)  ; encendemos solo el \"master enable\"\n        rts\n\n;----------------------------------------------------------------\n; Libera el hardware: restaura DMA, interrupciones y multitasking.\n;----------------------------------------------------------------\nrelease_system:\n        or.w    #$8000,old_dma      ; bit 15 = \"SET\" (no \"CLEAR\") al escribir\n        move.w  old_dma,DMACON(a5)  ; restauramos el estado de DMA original\n\n        move.l  4.w,a6\n        jsr     -138(a6)            ; Exec Permit() - reactiva el multitasking\n        jsr     -126(a6)            ; Exec Enable() - reactiva las interrupciones\n        rts\n\n;----------------------------------------------------------------\n; Utilidades de impresión (dos.library). print_before/print_after\n; fijan el mensaje en a3/d4 -registros preservados por cualquier\n; llamada a librería- y print_common hace el trabajo común.\n;----------------------------------------------------------------\nprint_before:\n        lea     msg_before,a3\n        move.l  #len_before,d4\n        bra     print_common\n\nprint_after:\n        lea     msg_after,a3\n        move.l  #len_after,d4\n        ; sigue en print_common\n\nprint_common:\n        move.l  4.w,a6\n        lea     dosname,a1\n        moveq   #0,d0\n        jsr     -552(a6)            ; Exec OpenLibrary(\"dos.library\")\n        move.l  d0,d7\n        beq     print_exit\n\n        move.l  d7,a6\n        jsr     -60(a6)             ; DOS Output()\n        move.l  d0,d1\n\n        move.l  a3,d2               ; d2 = puntero al buffer (desde a3, no a0)\n        move.l  d4,d3               ; d3 = longitud (desde d4, no d3 directo)\n        jsr     -48(a6)             ; DOS Write(d1, d2, d3)\n\n        move.l  4.w,a6\n        move.l  d7,a1\n        jsr     -414(a6)            ; Exec CloseLibrary()\nprint_exit:\n        rts\n\n        SECTION data,DATA\n\ndosname:\n        dc.b    \"dos.library\",0\n        EVEN\n\nmsg_before:\n        dc.b    \"Antes: tomando el control del hardware...\",10\nlen_before EQU  *-msg_before\n\nmsg_after:\n        dc.b    \"Despues: hardware liberado, el SO sigue operativo.\",10\nlen_after  EQU  *-msg_after\n        EVEN\n\ncolortable:\n        dc.w    $000\n        dc.w    $f00\n        dc.w    $0f0\n        dc.w    $00f\n        dc.w    $ff0\n        dc.w    $0ff\n        dc.w    $f0f\n        dc.w    $fff\n\nold_dma:\n        dc.w    0\n"
			},
