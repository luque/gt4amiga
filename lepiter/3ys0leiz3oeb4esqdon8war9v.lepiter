				"uid" : {
					"__type" : "uid",
					"uidString" : "LG+OdGwnSAuj7NS+viRp7w=="
				},
				"code" : "\"Paso 2: instalar la lista. BPLEN off, COPEN off, COP1LCH/L, COPEN on.\"\n| monitor clist |\nmonitor := GT4AmigaMonitorClient default.\nclist := Smalltalk at: #GT4ACopperList.\n{ 16rDFF096 -> 16r0100.                      \"BPLEN off (bit15=0 borra)\"\n  16rDFF096 -> 16r0080.                      \"COPEN off\"\n  16rDFF080 -> (clist bitShift: -16).        \"COP1LCH: word alta\"\n  16rDFF082 -> (clist bitAnd: 16rFFFF).      \"COP1LCL: word baja\"\n  16rDFF096 -> 16r8080 }                     \"COPEN on (bit15=1 activa)\"\n\tdo: [ :pair |\n\t\t(monitor writeMemoryAt: pair key size: 2 value: pair value)\n\t\t\tifFalse: [ ^ 'ack perdido escribiendo ' , pair key printStringHex , ' — reevalúa este snippet' ] ].\n'copper list instalada — mira la pantalla del Amiga'"
			},
			{
