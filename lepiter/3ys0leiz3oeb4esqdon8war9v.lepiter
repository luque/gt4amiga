						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-09T18:57:35.65841+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-09T18:57:35.65841+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "nU+/TAcVTzS9gJLShX/4Jg=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "Paso 2, la instalación — con dos precauciones aprendidas a base de pantallas azules. Primera: COP1LC es un par de registros de 16 bits (COP1LCH $DFF080 / COP1LCL $DFF082); lo escribimos como dos words separadas y con el DMA del Copper apagado durante el cambio, porque si el blanking vertical llega con el puntero a medio actualizar, el Copper arranca en una dirección corrupta. Segunda: apagamos el DMA de bitplanes (bit BPLEN de DMACON, $DFF096 — escribir con bit 15 a 0 borra bits, con bit 15 a 1 los activa) para que la pantalla muestre limpiamente los colores del Copper; el Workbench sigue vivo debajo, solo que invisible. Tras este snippet la pantalla debe partirse: azul arriba, naranja abajo, frontera en la línea 130. El puntero del ratón desaparece también (sus punteros de sprite los reponía la lista del sistema)."
			},
			{
