					"uidString" : "HiY7aotRS167R0OKoq9o7w=="
				},
				"code" : "; Copper bars nativas: tres rasterbars animadas por el 68000 a 50 fps.\n; OS-friendly: WaitTOF marca el compas, la copper list vive en una\n; seccion DATA_C (el cargador la coloca en chip RAM), y al salir se\n; restaura la lista del sistema desde GfxBase->LOFlist.\n\n        SECTION code,CODE\n\nstart:\n        movem.l d2-d7/a2-a6,-(sp)       ; convencion del stub de X: el\n                                        ; programa preserva d2-d7/a2-a6\n        move.l  4.w,a6                  ; ExecBase\n        lea     gfxname(pc),a1\n        jsr     -408(a6)                ; OldOpenLibrary\n        tst.l   d0\n        beq     salir\n        move.l  d0,a5                   ; GfxBase\n\n        bsr     construir               ; rellena los WAIT+MOVE de las barras\n        bsr     animar                  ; posiciones del frame 0\n\n        lea     $DFF000,a4\n        move.w  #$0100,$96(a4)          ; BPLEN off\n        move.w  #$0080,$96(a4)          ; COPEN off\n        move.l  #clist,$80(a4)          ; COP1LC (H y L de una vez)\n        move.w  #$8080,$96(a4)          ; COPEN on\n\n        move.w  #500-1,d7               ; 500 frames = 10 s en PAL\nbucle:\n        move.l  a5,a6\n        jsr     -270(a6)                ; WaitTOF: el metronomo, un tick por frame\n        bsr     animar\n        dbf     d7,bucle\n\n        lea     $DFF000,a4\n        move.w  #$0080,$96(a4)          ; COPEN off\n        move.l  50(a5),$80(a4)          ; COP1LC = GfxBase->LOFlist\n        move.w  #$8180,$96(a4)          ; BPLEN y COPEN de vuelta\n\n        move.l  a5,a1\n        move.l  4.w,a6\n        jsr     -414(a6)                ; CloseLibrary\nsalir:\n        movem.l (sp)+,d2-d7/a2-a6\n        moveq   #0,d0\n        rts\n\n; --- construir: 31 pares WAIT+MOVE por barra; el color sale de la\n;     tabla de sombras segun la distancia al centro de la barra\nconstruir:\n        lea     barras(pc),a3\n        moveq   #3-1,d3\n.barra: move.l  (a3)+,a0                ; bloque destino en la copper list\n        move.l  (a3)+,a1                ; tabla de 16 sombras\n        addq.l  #2,a3                   ; saltar la base (la usa animar)\n        moveq   #0,d0                   ; linea 0..30\n.linea: move.w  d0,d1\n        sub.w   #15,d1\n        bpl.s   .abs\n        neg.w   d1                      ; d1 = distancia al centro (0..15)\n.abs:   move.w  #$0001,(a0)+            ; WAIT (la posicion la pone animar)\n        move.w  #$FF00,(a0)+\n        move.w  #$0180,(a0)+            ; MOVE COLOR00\n        add.w   d1,d1\n        move.w  (a1,d1.w),(a0)+         ; la sombra de esta linea\n        addq.w  #1,d0\n        cmp.w   #31,d0\n        blt.s   .linea\n        dbf     d3,.barra\n        rts\n\n; --- animar: fase += velocidad, posicion = base + seno[fase],\n;     y reescribir los 31 WAITs de cada barra (el unico trabajo por frame)\nanimar:\n        lea     barras(pc),a3\n        lea     estado,a2\n        moveq   #3-1,d3\n.barra: move.l  (a3)+,a0                ; bloque de la barra\n        addq.l  #4,a3                   ; saltar la tabla de sombras\n        move.w  (a3)+,d4                ; base vertical (centro - 15)\n        move.w  (a2),d0                 ; fase\n        add.w   2(a2),d0                ; fase += velocidad\n        and.w   #63,d0\n        move.w  d0,(a2)\n        addq.l  #4,a2\n        lea     seno(pc),a1\n        move.b  (a1,d0.w),d1\n        ext.w   d1\n        add.w   d4,d1                   ; linea de arranque de la barra\n        lsl.w   #8,d1\n        addq.w  #1,d1                   ; WAIT word = (linea<<8)|1\n        moveq   #31-1,d2\n.wait:  move.w  d1,(a0)\n        addq.l  #8,a0                   ; al WAIT del siguiente par\n        add.w   #$0100,d1               ; linea + 1\n        dbf     d2,.wait\n        dbf     d3,.barra\n        rts\n\n; --- por barra: bloque en la lista, tabla de sombras, base vertical.\n;     Cada barra oscila en su propia banda y NUNCA cruza a la vecina:\n;     la copper list debe quedar siempre ordenada respecto al haz.\nbarras: dc.l    barra1,roja\n        dc.w    65                      ; centro 80, banda 49-111\n        dc.l    barra2,dorada\n        dc.w    135                     ; centro 150, banda 119-181\n        dc.l    barra3,azul\n        dc.w    205                     ; centro 220, banda 189-251\n\n; sombras por distancia al centro (0=centro..15=borde): 15*sin(t*pi/2)\nroja:   dc.w    $F22,$F22,$F22,$E22,$E22,$D22,$C22,$B22\n        dc.w    $A22,$911,$811,$611,$511,$300,$200,$000\ndorada: dc.w    $FB2,$FB2,$FB2,$EB1,$EB1,$DA1,$C91,$B81\n        dc.w    $A81,$971,$861,$651,$541,$320,$220,$000\nazul:   dc.w    $47F,$47F,$47F,$46E,$46E,$36D,$35C,$35B\n        dc.w    $35A,$249,$248,$236,$125,$113,$112,$000\n\n; la tabla de senos: 64 entradas, amplitud 16, bytes con signo.\n; El arma secreta de toda demo: sin FPU, el seno se precalcula.\nseno:   dc.b    0,2,3,5,6,8,9,10,11,12,13,14,15,15,16,16\n        dc.b    16,16,16,15,15,14,13,12,11,10,9,8,6,5,3,2\n        dc.b    0,-2,-3,-5,-6,-8,-9,-10,-11,-12,-13,-14,-15,-15,-16,-16\n        dc.b    -16,-16,-16,-15,-15,-14,-13,-12,-11,-10,-9,-8,-6,-5,-3,-2\n\ngfxname:\n        dc.b    'graphics.library',0\n        EVEN\n\n; --- la copper list: DATA_C = el cargador la pone en CHIP RAM,\n;     que es la unica memoria que el Copper puede leer\n        SECTION data,DATA_C\n\nclist:  dc.w    $0180,$0000             ; COLOR00 negro en lo alto del frame\nbarra1: ds.w    4*31\nbarra2: ds.w    4*31\nbarra3: ds.w    4*31\n        dc.w    $FFFF,$FFFE             ; fin de lista\n\nestado: dc.w    0,1                     ; fase y velocidad, barra roja\n        dc.w    21,2                    ; dorada (desfasada)\n        dc.w    43,3                    ; azul"
			},
