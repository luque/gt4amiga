				},
				"code" : "| maquina |\nmaquina := GT4AmigaMachine default.\nmaquina refresh.\nmaquina memoryGaugeRows collect: [ :fila | fila first -> fila second ]"
			},
			{
				"__type" : "textSnippet",
				"children" : {
