					"uidString" : "TqCqX4FwRxeM9mOtttSs5A=="
				},
				"code" : "| catalogo |\ncatalogo := GT4AmigaMachine default catalog.\n(catalogo copperMovesTo: 16r100)\n\tcollect: [ :v | '$' , (v printPaddedWith: $0 to: 4 base: 16) ]"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
