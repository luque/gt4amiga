						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-15T23:52:14.838723+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-07-15T23:52:14.838723+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "LefTctr7T7ODejFuKYB0tg=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "El experimento: abre la figura de arriba y, sin cerrarla, evalúa el snippet siguiente. Apaga el DMA de bitplanes durante cinco segundos — la pantalla del emulador se queda negra, porque Denise deja de recibir datos — y en la figura los ~80 slots azules se vuelven pálidos: durante esos cinco segundos son slots libres, y el 68000 (y el blitter) corren notablemente más rápido. Es la lección de la figura 6-12 del AHRM al revés: un display hires de 4 bitplanes necesita TODOS los slots durante el display y expulsa al 68000 del bus; apagar BPLEN se los devuelve todos. (El Workbench hires de 2 planos que estás viendo usa 2 de cada 4 slots de la ventana de fetch.)"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
